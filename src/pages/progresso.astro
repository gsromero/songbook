---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const musicas = await getCollection('musicas');
const total = musicas.length;

const niveis = ['N1', 'N2', 'N3', 'N4', 'N5'] as const;
const statuses = ['toca_bem', 'toca_parcial', 'wishlist', 'nao_classificado'] as const;

const porNivel = Object.fromEntries(
  niveis.map(n => [n, musicas.filter(m => m.data.nivel === n).length])
) as Record<string, number>;

const porStatus = Object.fromEntries(
  statuses.map(s => [s, musicas.filter(m => m.data.status === s).length])
) as Record<string, number>;

const statusLabels: Record<string, string> = {
  toca_bem: '🟢 Toco bem',
  toca_parcial: '🟡 Parcial',
  wishlist: '🔴 Wishlist',
  nao_classificado: '⚪ Sem status',
};
---

<Base title="Progress">
  <div class="page-head">
    <h1 class="page-title" data-i18n="progress_title">Progress</h1>
    <p class="page-sub progress-total" data-total={total}>{total} songs total</p>
  </div>

  <div class="grid-2">
    <section class="paper-card panel">
      <h2 class="panel-title" data-i18n="by_level">By level</h2>
      <div class="bars">
        {niveis.map(n => {
          const count = porNivel[n] ?? 0;
          const pct = total > 0 ? Math.round((count / total) * 100) : 0;
          return (
            <div class="bar-row">
              <div class="bar-meta">
                <span class="bar-label">{n}</span>
                <span class="bar-count">{count} <span class="of">/ {total}</span></span>
              </div>
              <div class="bar-track">
                <div class="bar-fill" style={`width: ${pct}%`} aria-valuenow={count} aria-valuemax={total} role="progressbar" />
              </div>
            </div>
          );
        })}
      </div>
    </section>

    <section class="paper-card panel">
      <h2 class="panel-title" data-i18n="by_status">By status</h2>
      <div class="bars">
        {statuses.map(s => {
          const count = porStatus[s] ?? 0;
          const pct = total > 0 ? Math.round((count / total) * 100) : 0;
          return (
            <div class="bar-row">
              <div class="bar-meta">
                <span class="bar-label-soft">{statusLabels[s]}</span>
                <span class="bar-count">{count}</span>
              </div>
              <div class="bar-track">
                <div class="bar-fill bar-fill-soft" style={`width: ${pct}%`} aria-valuenow={count} aria-valuemax={total} role="progressbar" />
              </div>
            </div>
          );
        })}
      </div>
    </section>

    <section class="paper-card panel span-2">
      <h2 class="panel-title" data-i18n="overview">Overview</h2>
      <div class="overview">
        {statuses.map(s => (
          <div class="overview-cell">
            <div class="overview-num">{porStatus[s] ?? 0}</div>
            <div class="overview-label">{statusLabels[s]}</div>
          </div>
        ))}
      </div>
    </section>
  </div>
</Base>

<style>
  .page-head { margin-bottom: 2rem; }
  .page-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    color: var(--ink);
    letter-spacing: -0.01em;
  }
  .page-sub { font-style: italic; color: var(--ink-soft); font-size: 0.95rem; }

  .grid-2 {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.2rem;
  }
  @media (min-width: 768px) {
    .grid-2 { grid-template-columns: 1fr 1fr; }
    .span-2 { grid-column: 1 / -1; }
  }

  .panel { padding: 1.4rem 1.4rem 1.6rem; }
  .panel-title {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: 1.2rem;
    color: var(--ink);
    margin-bottom: 1rem;
  }

  .bars { display: flex; flex-direction: column; gap: 0.9rem; }
  .bar-row { }
  .bar-meta {
    display: flex;
    justify-content: space-between;
    margin-bottom: 0.3rem;
    font-size: 0.9rem;
  }
  .bar-label {
    font-family: var(--font-mono);
    font-weight: 700;
    color: var(--accent);
  }
  .bar-label-soft {
    font-family: var(--font-serif);
    color: var(--ink);
  }
  .bar-count {
    font-family: var(--font-mono);
    color: var(--ink-soft);
    font-size: 0.85rem;
  }
  .of { opacity: 0.5; }
  .bar-track {
    height: 6px;
    background: color-mix(in srgb, var(--paper-line) 60%, transparent);
    border-radius: 3px;
    overflow: hidden;
  }
  .bar-fill {
    height: 100%;
    background: var(--accent);
    border-radius: 3px;
    transition: width 0.3s;
  }
  .bar-fill-soft {
    background: var(--accent-soft);
  }

  .overview {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }
  @media (min-width: 640px) {
    .overview { grid-template-columns: repeat(4, 1fr); }
  }
  .overview-cell {
    text-align: center;
    padding: 0.8rem 0.5rem;
  }
  .overview-num {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 2.4rem;
    color: var(--accent);
    line-height: 1;
  }
  .overview-label {
    margin-top: 0.4rem;
    font-style: italic;
    font-size: 0.85rem;
    color: var(--ink-soft);
  }
</style>

<script>
  import { getLang } from '../lib/i18n.js';

  function updateTotal() {
    const el = document.querySelector<HTMLElement>('.progress-total');
    if (!el) return;
    const n = Number(el.dataset['total'] ?? 0);
    const lang = getLang();
    const word = lang === 'pt' ? (n !== 1 ? 'músicas no total' : 'música no total') : (n !== 1 ? 'songs total' : 'song total');
    el.textContent = `${n} ${word}`;
  }

  updateTotal();
  document.addEventListener('gm:lang-change', updateTotal);
</script>

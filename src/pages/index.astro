---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import StatusBadge from '../components/StatusBadge.astro';
import Filtros from '../components/Filtros.astro';

const musicas = await getCollection('musicas');
musicas.sort((a, b) => {
  const nivelOrder = ['N1', 'N2', 'N3', 'N4', 'N5'];
  const nd = (nivelOrder.indexOf(a.data.nivel) ?? 0) - (nivelOrder.indexOf(b.data.nivel) ?? 0);
  if (nd !== 0) return nd;
  return a.data.artista.localeCompare(b.data.artista, 'pt');
});

const artistas = [...new Set(musicas.map(m => m.data.artista))];
const tags = [...new Set(musicas.flatMap(m => m.data.tags ?? []))];

const base = import.meta.env.BASE_URL;
const total = musicas.length;
---

<Base title="Repertoire">
  <div class="page-head">
    <h1 class="page-title" data-i18n="repertoire">Repertoire</h1>
    <p class="page-sub songs-count" data-total={total}>{total} songs</p>
  </div>

  <Filtros artistas={artistas} tags={tags} />

  <div class="card-grid">
    {musicas.map(m => (
      <a
        href={`${base}musica/${m.data.slug}`}
        class="music-card"
        data-musica-card
        data-titulo={m.data.titulo}
        data-artista={m.data.artista}
        data-nivel={m.data.nivel}
        data-status={m.data.status}
        data-tags={(m.data.tags ?? []).join(',')}
      >
        <div class="card-top">
          <span class="meta-badge">{m.data.nivel}</span>
          <StatusBadge status={m.data.status} />
        </div>

        <h2 class="card-title">{m.data.titulo}</h2>
        <p class="card-artist">{m.data.artista}</p>

        <div class="card-foot">
          {m.data.tom && <span class="card-tom">{m.data.tom}</span>}
          {(m.data.tags ?? []).slice(0, 3).map(tag => (
            <span class="card-tag">#{tag}</span>
          ))}
        </div>
      </a>
    ))}
  </div>
</Base>

<style>
  .page-head {
    margin-bottom: 1.5rem;
  }
  .page-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    color: var(--ink);
    letter-spacing: -0.01em;
  }
  .page-sub {
    font-style: italic;
    color: var(--ink-soft);
    font-size: 0.95rem;
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(15rem, 1fr));
    gap: 1rem;
  }

  .music-card {
    display: flex;
    flex-direction: column;
    background: var(--bg-tint);
    border: 1px solid var(--paper-line);
    border-radius: 6px;
    padding: 0.9rem 1rem 1rem;
    box-shadow: 0 2px 8px var(--shadow);
    text-decoration: none;
    color: inherit;
    transition: transform 0.15s, box-shadow 0.15s, border-color 0.15s;
  }
  .music-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 18px var(--shadow);
    border-color: var(--accent-soft);
  }

  .card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: 0.6rem;
  }
  .card-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.15rem;
    line-height: 1.2;
    color: var(--ink);
    margin-bottom: 0.15rem;
  }
  .card-artist {
    font-style: italic;
    font-size: 0.85rem;
    color: var(--ink-soft);
    margin-bottom: 0.7rem;
  }
  .card-foot {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    align-items: center;
    margin-top: auto;
  }
  .card-tom {
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: 0.75rem;
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 8%, transparent);
    padding: 0.05rem 0.4rem;
    border-radius: 3px;
  }
  .card-tag {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.75rem;
    color: var(--ink-soft);
    opacity: 0.7;
  }
</style>

<script>
  import { getLang } from '../lib/i18n.js';

  function updateSongsCount() {
    const el = document.querySelector<HTMLElement>('.songs-count');
    if (!el) return;
    const n = Number(el.dataset['total'] ?? 0);
    const lang = getLang();
    const word = lang === 'pt' ? (n !== 1 ? 'músicas' : 'música') : (n !== 1 ? 'songs' : 'song');
    el.textContent = `${n} ${word}`;
  }

  updateSongsCount();
  document.addEventListener('gm:lang-change', updateSongsCount);
</script>

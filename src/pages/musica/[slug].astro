---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import StatusBadge from '../../components/StatusBadge.astro';
import Cifra from '../../components/Cifra.astro';
import ColunaToggle from '../../components/ColunaToggle.astro';

export async function getStaticPaths() {
  const musicas = await getCollection('musicas');
  return musicas.map(entry => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { titulo, artista, nivel, status, tom, tomOriginal, tags, links, observacoes } = entry.data;
const slug = entry.data.slug;

const rawBody = entry.body ?? '';
const hasContent = rawBody.trim().length > 0 && !rawBody.trim().startsWith('<!--');

const base = import.meta.env.BASE_URL;
---

<Base title={titulo} description={`${titulo} — ${artista}`} full>
  <div class="back-link">
    <a href={base} data-i18n="back_repertoire">← Repertoire</a>
  </div>

  <header class="song-head">
    <h1 class="song-title">{titulo}</h1>
    <p class="song-artist">{artista}{tomOriginal ? <span class="album-sep"> · </span> : ''}{tomOriginal ? <span class="album-info">Tom original: <strong>{tomOriginal}</strong></span> : ''}</p>
    <div class="song-meta">
      <span class="meta-badge">{nivel}</span>
      <span class="meta-sep">·</span>
      <StatusBadge status={status} />
      {tom && (
        <>
          <span class="meta-sep">·</span>
          <span class="meta-item"><span data-i18n="playing_in">Playing in:</span> <strong id="current-key-display">{tom}</strong></span>
        </>
      )}
    </div>

    {(tags ?? []).length > 0 && (
      <div class="song-tags">
        {(tags ?? []).map(tag => (
          <span class="song-tag">#{tag}</span>
        ))}
      </div>
    )}

    {observacoes && (
      <p class="song-obs">{observacoes}</p>
    )}

    {(links?.cifraclub || links?.youtube) && (
      <div class="song-links">
        {links?.cifraclub && (
          <a href={links.cifraclub} target="_blank" rel="noopener">Cifra Club ↗</a>
        )}
        {links?.youtube && (
          <a href={links.youtube} target="_blank" rel="noopener">YouTube ↗</a>
        )}
      </div>
    )}
  </header>

  <div class="controls song-controls">
    {tom && (
      <div class="ctrl-group">
        <span class="ctrl-label" data-i18n="key_label">Key</span>
        <button class="btn" id="transpose-down" type="button" data-i18n-aria="transpose_down" aria-label="Transpose down">−</button>
        <span class="transpose-display" id="transpose-display">±0</span>
        <button class="btn" id="transpose-up" type="button" data-i18n-aria="transpose_up" aria-label="Transpose up">+</button>
        <button class="btn btn-ghost" id="transpose-reset" type="button" data-i18n="reset">Reset</button>
      </div>
    )}
    <ColunaToggle targetId="cifra-columns" />
  </div>

  {hasContent
    ? <Cifra rawCifra={rawBody} tom={tom} tomOriginal={tomOriginal} slug={slug} />
    : (
      <div class="paper-card empty-cifra">
        <p data-i18n="no_cifra">Chord sheet not yet added.</p>
        <p class="hint">
          Edite <code>src/content/musicas/{slug}.md</code> para preencher.
        </p>
      </div>
    )
  }
</Base>

<script>
  const NOTES = ['C','C#','D','D#','E','F','F#','G','G#','A','A#','B'];
  const FLAT_TO_SHARP: Record<string,string> = {Bb:'A#',Db:'C#',Eb:'D#',Gb:'F#',Ab:'G#'};

  function transposeNote(note: string, n: number): string {
    const base = FLAT_TO_SHARP[note] ?? note;
    const idx = NOTES.indexOf(base);
    if (idx === -1) return note;
    return NOTES[((idx + n) % 12 + 12) % 12] ?? note;
  }

  let offset = 0;
  const displayEl = document.getElementById('transpose-display');
  const keyEl = document.getElementById('current-key-display');

  // Read base key from the server-rendered text
  const baseKey = keyEl?.textContent?.trim() ?? '';

  function dispatch(n: number) {
    offset = Math.max(-6, Math.min(6, n));
    if (displayEl) displayEl.textContent = offset === 0 ? '±0' : offset > 0 ? `+${offset}` : String(offset);
    document.dispatchEvent(new CustomEvent('gm:transpose', { detail: offset }));
  }

  // Update key display when Cifra script responds
  document.addEventListener('gm:transpose-changed', ((e: CustomEvent<{offset: number; currentKey: string}>) => {
    if (keyEl) keyEl.textContent = e.detail.currentKey;
    if (displayEl) displayEl.textContent = e.detail.offset === 0 ? '±0' : e.detail.offset > 0 ? `+${e.detail.offset}` : String(e.detail.offset);
  }) as EventListener);

  document.getElementById('transpose-up')?.addEventListener('click', () => dispatch(offset + 1));
  document.getElementById('transpose-down')?.addEventListener('click', () => dispatch(offset - 1));
  document.getElementById('transpose-reset')?.addEventListener('click', () => dispatch(0));
</script>

<style>
  .back-link { margin-bottom: 1rem; }
  .back-link a {
    font-size: 0.85rem;
    color: var(--ink-soft);
    text-decoration: none;
    font-style: italic;
  }
  .back-link a:hover { color: var(--accent); }

  .song-head {
    text-align: left;
    margin-bottom: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--paper-line);
    max-width: 56rem;
  }
  .album-sep { opacity: 0.4; margin: 0 0.2rem; }
  .album-info { font-style: italic; font-size: 0.9em; }
  .album-info strong { color: var(--accent); font-family: var(--font-mono); font-style: normal; }

  .song-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.6rem;
    font-family: var(--font-serif);
    color: var(--ink-soft);
    font-size: 0.95rem;
  }
  .meta-sep { opacity: 0.4; }
  .meta-item strong {
    color: var(--accent);
    font-family: var(--font-mono);
    font-weight: 600;
    margin-left: 0.2rem;
  }
  .song-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.7rem;
  }
  .song-tag {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.8rem;
    color: var(--ink-soft);
    border: 1px solid var(--paper-line);
    padding: 0.05rem 0.5rem;
    border-radius: 3px;
    background: color-mix(in srgb, var(--bg) 50%, transparent);
  }
  .song-obs {
    margin-top: 0.8rem;
    font-style: italic;
    font-size: 0.95rem;
    color: var(--ink-soft);
    border-left: 2px solid var(--accent-soft);
    padding-left: 0.7rem;
  }
  .song-links {
    margin-top: 0.8rem;
    display: flex;
    gap: 1rem;
    font-size: 0.85rem;
  }
  .song-links a { color: var(--accent); text-decoration: underline; text-underline-offset: 3px; }
  .song-links a:hover { color: var(--chord-hover); }

  .song-controls { margin-bottom: 1.2rem; }

  .transpose-display {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--accent);
    min-width: 2.4rem;
    text-align: center;
    font-weight: 600;
  }

  .btn-ghost {
    border-color: transparent;
    background: transparent;
    color: var(--ink-soft);
    font-size: 0.8rem;
  }
  .btn-ghost:hover {
    color: var(--accent);
    background: transparent;
    border-color: var(--paper-line);
  }

  .empty-cifra {
    padding: 3rem 1rem;
    text-align: center;
    color: var(--ink-soft);
    font-style: italic;
  }
  .empty-cifra .hint { font-size: 0.85rem; margin-top: 0.4rem; opacity: 0.7; }
  .empty-cifra code {
    font-family: var(--font-mono);
    font-style: normal;
    background: var(--bg);
    padding: 0.1rem 0.4rem;
    border-radius: 3px;
    border: 1px solid var(--paper-line);
  }
</style>

---
import Base from '../../layouts/Base.astro';
---

<Base title="Cifra" full={true}>
  <div id="musica-loading" style="text-align:center;padding:3rem;font-style:italic;color:var(--ink-soft);">Carregando…</div>
  <div id="musica-app" style="display:none;">

    <!-- Cabeçalho da música -->
    <div class="musica-header">
      <a href="/" class="back-link">← Repertório</a>
      <div class="musica-meta">
        <h1 id="m-titulo" class="musica-titulo"></h1>
        <div class="musica-info-row">
          <a id="m-artista" href="#" class="musica-artista"></a>
          <span class="meta-sep">·</span>
          <span id="m-tom-original" class="tom-original" style="display:none;"></span>
        </div>
        <div class="musica-actions-row">
          <button id="btn-favorito" class="btn-heart" title="Favoritar" aria-label="Favoritar">♡</button>
          <button id="btn-editar-musica" class="btn btn-small" type="button">Editar</button>
          <button id="btn-apagar-musica" class="btn btn-small btn-danger" type="button">Apagar</button>
          <span id="m-adicionado-por" class="adicionado-por" style="display:none;"></span>
        </div>
      </div>
    </div>


    <!-- Tags -->
    <div id="m-tags" class="musica-tags"></div>

    <!-- Links externos -->
    <div id="m-links" class="musica-links" style="display:none;">
      <a id="link-cifraclub" href="#" target="_blank" rel="noopener" style="display:none;" class="ext-link">Cifra Club ↗</a>
      <a id="link-youtube-btn" href="#" target="_blank" rel="noopener" style="display:none;" class="ext-link ext-link-yt">YouTube ↗</a>
    </div>

    <!-- YouTube embed -->
    <div id="yt-embed-wrap" style="display:none;" class="yt-embed-wrap">
      <iframe id="yt-embed" class="yt-embed" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
    </div>

    <!-- Controles da cifra -->
    <div class="cifra-controls">
      <div class="ctrl-group">
        <span class="ctrl-label">Tom</span>
        <div class="btn-row">
          <button class="btn transpose-btn" data-dir="-1" type="button">−</button>
          <span id="transpose-display" class="transpose-display">–</span>
          <button class="btn transpose-btn" data-dir="+1" type="button">+</button>
          <button class="btn btn-ghost" id="btn-reset-transpose" type="button">Reset</button>
          <button class="btn btn-salvar-tom" id="btn-salvar-tom" style="display:none;">Salvar meu tom</button>
          <span id="tom-saved-msg" class="tom-saved" style="display:none;">✓ salvo</span>
        </div>
      </div>
      <div class="ctrl-group">
        <span class="ctrl-label">Colunas</span>
        <div class="btn-row" style="gap: 0.3rem;">
          {[1,2,3,4].map(n => <button class="btn col-btn" data-cols={n} aria-pressed={n === 1} type="button">{n}</button>)}
        </div>
      </div>
      <div class="ctrl-group">
        <button id="btn-pratica" class="btn" type="button">🎯 Modo Prática</button>
      </div>
    </div>

    <!-- Cifra -->
    <div id="cifra-wrap" class="cifra-wrap">
      <div id="cifra-columns" class="cifra-columns" style="--num-cols: 1"></div>
      <div id="chord-tooltip" class="chord-tooltip" role="tooltip" aria-hidden="true">
        <div class="tooltip-name" id="tooltip-name"></div>
        <div class="tooltip-diagram" id="tooltip-diagram"></div>
      </div>
    </div>

    <!-- Acordes utilizados -->
    <section id="acordes-section" class="acordes-section" style="display:none;"></section>

    <!-- Músicas parecidas -->
    <section id="similares-section" style="display:none; margin-top:2rem;">
      <h2 class="section-label">Você pode gostar</h2>
      <div id="similares-grid" class="recentes-grid"></div>
    </section>

  </div>
  <div id="musica-error" style="display:none;text-align:center;padding:3rem;color:var(--ink-soft);font-style:italic;"></div>

  <div id="modal-editar-musica" class="modal-overlay" style="display:none;">
    <div class="modal-box modal-box-wide">
      <div class="modal-header">
        <span class="modal-title">Editar música</span>
        <button class="modal-close" id="btn-fechar-editar" type="button">✕</button>
      </div>
      <form id="form-editar-musica" class="form-editar">
        <div class="field">
          <label>Título</label>
          <input id="edit-titulo" type="text" required />
        </div>
        <div class="field">
          <label>Artista</label>
          <input id="edit-artista" type="text" required />
        </div>
        <div class="field-row">
          <div class="field">
            <label>Tom da cifra</label>
            <input id="edit-tom" type="text" maxlength="3" placeholder="A" />
          </div>
          <div class="field">
            <label>Tom original</label>
            <input id="edit-tom-original" type="text" maxlength="3" placeholder="D" />
          </div>
        </div>
        <div class="field">
          <label>Tags <span class="hint">(separadas por vírgula)</span></label>
          <input id="edit-tags" type="text" placeholder="mpb, dedilhado-simples" />
        </div>
        <div class="field">
          <label>Link CifraClub <span class="hint">(opcional)</span></label>
          <input id="edit-link-cifraclub" type="url" placeholder="https://www.cifraclub.com.br/artista/musica/" />
        </div>
        <div class="field">
          <label>Link YouTube <span class="hint">(opcional)</span></label>
          <input id="edit-link-youtube" type="url" placeholder="https://youtube.com/watch?v=..." />
        </div>
        <div class="field">
          <label>Cifra</label>
          <textarea id="edit-cifra" required rows="16" spellcheck="false"></textarea>
        </div>
        <p id="edit-error" class="login-error" style="display:none;"></p>
        <div class="modal-actions">
          <button type="button" id="btn-cancelar-editar" class="btn btn-ghost">Cancelar</button>
          <button type="submit" id="btn-salvar-editar" class="btn btn-accent">Salvar</button>
        </div>
      </form>
    </div>
  </div>
</Base>

<script>
  // ── Slug da URL ───────────────────────────────────────────────────────────────
  const slug = window.location.pathname.replace(/^\/musica\//, '').replace(/\/$/, '');
  let currentMusica: any = null;

  // ── Constantes de transpose ───────────────────────────────────────────────────
  const NOTES = ['C','C#','D','D#','E','F','F#','G','G#','A','A#','B'];
  const FLAT_TO_SHARP: Record<string,string> = {Bb:'A#',Db:'C#',Eb:'D#',Gb:'F#',Ab:'G#'};

  function transposeNote(note: string, n: number): string {
    const base = FLAT_TO_SHARP[note] ?? note;
    const idx = NOTES.indexOf(base);
    if (idx === -1) return note;
    return NOTES[((idx + n) % 12 + 12) % 12] ?? note;
  }
  function transposeChordName(chord: string, n: number): string {
    if (n === 0) return chord;
    const m = chord.match(/^([A-G][b#]?)(.*)$/);
    if (!m) return chord;
    return transposeNote(m[1] ?? '', n) + (m[2] ?? '');
  }

  // ── Parse cifra ───────────────────────────────────────────────────────────────
  // [Mm]? depois de \d* permite sufixos como 7M (maj7), 7m (m7) usados no CifraClub
  const CHORD_TOKEN = /^[A-G][b#]?(?:maj|min|m|dim|aug|sus|add|°|º|ø)?\d*[Mm]?(?:[b#]\d+)?(?:\([^)]+\))?(?:\/[A-G][b#]?)?$/;
  const CHORD_FIND_SRC = '[A-G][b#]?(?:maj|min|m|dim|aug|sus|add|°|º|ø)?\\d*[Mm]?(?:[b#]\\d+)?(?:\\([^)]+\\))?(?:\\/[A-G][b#]?)?';

  type ChordPos = { c: string; col: number };
  type Line = { type: 'cifra'; chords: ChordPos[]; lyric: string } | { type: 'chords-only'; chords: ChordPos[] } | { type: 'lyric-only'; lyric: string };
  type Section = { header: string; lines: Line[] };

  function classifyLine(line: string): 'empty' | 'section' | 'chord' | 'lyric' {
    const t = line.trim();
    if (!t) return 'empty';
    if (/^\[.+\]$/.test(t)) return 'section';
    const tokens = t.split(/\s+/);
    const cc = tokens.filter(tok => CHORD_TOKEN.test(tok)).length;
    return cc / tokens.length >= 0.6 ? 'chord' : 'lyric';
  }

  function extractPositions(line: string): ChordPos[] {
    const re = new RegExp('\\b' + CHORD_FIND_SRC + '\\b', 'g');
    const out: ChordPos[] = [];
    let m;
    while ((m = re.exec(line)) !== null) {
      if (CHORD_TOKEN.test(m[0])) out.push({ c: m[0], col: m.index });
    }
    return out;
  }

  function parseCifra(raw: string): Section[] {
    const lines = raw.replace(/\r/g, '').split('\n');
    const sections: Section[] = [];
    let current: Section | null = null;
    let pending: ChordPos[] | null = null;
    function ensure() { if (!current) { current = { header: '', lines: [] }; sections.push(current); } }
    function flush() { if (pending) { ensure(); current!.lines.push({ type: 'chords-only', chords: pending }); pending = null; } }
    for (const line of lines) {
      const kind = classifyLine(line);
      if (kind === 'section') { flush(); current = { header: line.trim(), lines: [] }; sections.push(current); }
      else if (kind === 'empty') { flush(); }
      else if (kind === 'chord') { flush(); pending = extractPositions(line); }
      else { ensure(); if (pending) { current!.lines.push({ type: 'cifra', chords: pending, lyric: line.replace(/\s+$/, '') }); pending = null; } else { current!.lines.push({ type: 'lyric-only', lyric: line.replace(/\s+$/, '') }); } }
    }
    flush();
    return sections;
  }

  // ── HTML render de cifra ──────────────────────────────────────────────────────
  function escHtml(s: string) { return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

  function renderChordLine(chords: ChordPos[]): string {
    let html = '', col = 0;
    for (const { c, col: t } of chords) {
      while (col < t) { html += ' '; col++; }
      const safe = escHtml(c);
      html += `<span class="chord" data-chord="${safe}" data-orig="${safe}">${safe}</span>`;
      col += c.length;
    }
    return html;
  }

  function renderCifraPairs(chords: ChordPos[], lyric: string): string {
    let html = '';
    let pos = 0;
    for (let i = 0; i < chords.length; i++) {
      const { c, col: start } = chords[i]!;
      const end = chords[i+1]?.col ?? lyric.length;
      // Texto antes deste acorde (sem acorde acima)
      if (start > pos) {
        html += `<span class="cifra-pair"><span class="chord-gap"></span><span class="lyric-slice">${escHtml(lyric.slice(pos, start))}</span></span>`;
      }
      const slice = lyric.slice(start, Math.min(end, lyric.length));
      const safe = escHtml(c);
      html += `<span class="cifra-pair"><span class="chord" data-chord="${safe}" data-orig="${safe}">${safe}</span><span class="lyric-slice">${escHtml(slice)}</span></span>`;
      pos = end;
    }
    // Texto restante após o último acorde
    if (pos < lyric.length) {
      html += `<span class="lyric-slice">${escHtml(lyric.slice(pos))}</span>`;
    }
    return html;
  }

  function sectionHTML(sec: Section, pratica: boolean): string {
    let html = '';
    if (sec.header) html += `<div class="cifra-header">${sec.header}</div>`;

    if (pratica) {
      // Coletar sequência de acordes desta seção em ordem
      const seq: string[] = [];
      for (const line of sec.lines) {
        if ('chords' in line) {
          for (const { c } of line.chords) {
            seq.push(transposeChordName(c, transposeOffset));
          }
        }
      }
      if (!seq.length) return '';
      const cards = seq.map(chord => {
        const svg = chordSvgs[chord] || chordSvgs[transposeChordName(chord, -transposeOffset)];
        return `<div class="pratica-card">
          <div class="pratica-chord-name">${escHtml(chord)}</div>
          ${svg
            ? `<div class="pratica-chord-svg">${svg}</div>`
            : `<div class="pratica-chord-no-svg">—</div>`}
        </div>`;
      }).join('');
      html += `<div class="pratica-seq">${cards}</div>`;
    } else {
      for (const line of sec.lines) {
        if (line.type === 'cifra') {
          html += `<div class="cifra-line has-pairs">${renderCifraPairs(line.chords, line.lyric)}</div>`;
        } else if (line.type === 'chords-only') {
          html += `<div class="cifra-line chord-line">${renderChordLine(line.chords)}</div><div class="cifra-line spacer"></div>`;
        } else {
          html += `<div class="cifra-line lyric-line">${escHtml(line.lyric)}</div>`;
        }
      }
    }

    return html ? `<div class="cifra-section-block">${html}</div>` : '';
  }

  // ── Columns ───────────────────────────────────────────────────────────────────
  let sections: Section[] = [];
  let numCols = Number(localStorage.getItem('gm:colunas') ?? '1');
  let praticaMode = false;

  function renderCifra() {
    const root = document.getElementById('cifra-columns')!;
    root.style.setProperty('--num-cols', String(numCols));
    root.innerHTML = '';

    const blocks = sections.map(s => sectionHTML(s, praticaMode)).filter(Boolean);
    if (numCols <= 1) {
      const col = document.createElement('div');
      col.className = 'cifra-column';
      col.innerHTML = blocks.join('');
      root.appendChild(col);
    } else {
      // Distribute evenly by line count
      const lineCount = (html: string) => (html.match(/cifra-line/g) || []).length + 3;
      const weights = blocks.map(lineCount);
      const total = weights.reduce((a,b)=>a+b,0);
      const target = total / numCols;
      const cols: string[][] = Array.from({length: numCols}, () => []);
      let ci = 0, acc = 0;
      blocks.forEach((b, i) => {
        if (ci < numCols - 1 && acc > 0 && acc + weights[i]!/2 > target) { ci++; acc = 0; }
        cols[ci]!.push(b);
        acc += weights[i]!;
      });
      cols.forEach(group => {
        if (!group.length) return;
        const col = document.createElement('div');
        col.className = 'cifra-column';
        col.innerHTML = group.join('');
        root.appendChild(col);
      });
    }

    syncColButtons();
    if (!praticaMode) {
      applyChordSpans(transposeOffset);
    }
    refreshTransposeUI();
    renderAcordesSection();
  }

  function syncColButtons() {
    document.querySelectorAll<HTMLElement>('.col-btn').forEach(btn => {
      btn.setAttribute('aria-pressed', String(Number(btn.dataset['cols']) === numCols));
    });
  }

  // ── Transpose ─────────────────────────────────────────────────────────────────
  let transposeOffset = 0;
  let resetOffset = 0;    // offset para voltar ao tom_original
  let chordSvgs: Record<string,string> = {};
  let baseTom = '';       // tom base da cifra (m.tom — key em que a cifra está escrita)
  let savedUserTom = '';  // tom salvo pelo usuário (m.user_tom)

  function offsetToReachKey(from: string, to: string): number {
    const a = NOTES.indexOf(FLAT_TO_SHARP[from] ?? from);
    const b = NOTES.indexOf(FLAT_TO_SHARP[to] ?? to);
    if (a === -1 || b === -1) return 0;
    return ((b - a) + 12) % 12;
  }

  function currentKey(): string {
    if (!baseTom) return '';
    return transposeNote(baseTom, transposeOffset);
  }

  // Atualiza display da nota e botão "Salvar meu tom" — sem efeitos colaterais
  function refreshTransposeUI() {
    const key = currentKey();
    const display = document.getElementById('transpose-display');
    if (display) display.textContent = key || (transposeOffset === 0 ? '±0' : (transposeOffset > 0 ? `+${transposeOffset}` : String(transposeOffset)));
    const btnSalvar = document.getElementById('btn-salvar-tom') as HTMLElement | null;
    if (btnSalvar) {
      btnSalvar.style.display = (key && key !== savedUserTom) ? '' : 'none';
    }
  }

  // Aplica transposição nos spans de acorde do modo normal
  function applyChordSpans(offset: number) {
    document.querySelectorAll<HTMLElement>('.chord[data-orig]').forEach(el => {
      const orig = el.dataset['orig'] ?? '';
      const name = transposeChordName(orig, offset);
      el.textContent = name;
      el.dataset['chord'] = name;
    });
  }

  function applyTranspose(offset: number, save = true) {
    transposeOffset = offset;
    if (save) {
      fetch(`/api/transpose/${slug}`, { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({ offset }) }).catch(() => {});
    }
    if (praticaMode) {
      // Re-renderiza cards de prática com o novo offset; renderCifra NÃO chama applyTranspose em modo prática
      renderCifra();
      return;
    }
    applyChordSpans(offset);
    refreshTransposeUI();
    renderAcordesSection();
  }

  // ── Tooltip ───────────────────────────────────────────────────────────────────
  const tooltip = document.getElementById('chord-tooltip')!;
  document.body.appendChild(tooltip);
  const tipName = document.getElementById('tooltip-name')!;
  const tipDiagram = document.getElementById('tooltip-diagram')!;
  let hideTimer: number | null = null;

  function showTooltip(el: HTMLElement) {
    if (hideTimer !== null) { clearTimeout(hideTimer); hideTimer = null; }
    const name = el.dataset['chord'] || '';
    tipName.textContent = name;
    const svg = chordSvgs[name] || chordSvgs[transposeChordName(name, -transposeOffset)];
    tipDiagram.innerHTML = svg || `<div style="font-size:0.75rem;color:var(--ink-soft);padding:0.5rem;font-style:italic;">Diagrama não disponível</div>`;
    tooltip.classList.add('visible');
    tooltip.setAttribute('aria-hidden', 'false');
  }
  function positionTooltip(x: number, y: number) {
    const tw = tooltip.offsetWidth || 120, th = tooltip.offsetHeight || 170;
    let left = x + 14, top = y + 14;
    if (x + tw + 24 > window.innerWidth) left = x - tw - 14;
    if (y + th + 24 > window.innerHeight) top = y - th - 14;
    tooltip.style.left = left + 'px'; tooltip.style.top = top + 'px';
  }
  function hideTooltipSoon() {
    if (!tooltip) return;
    hideTimer = window.setTimeout(() => { tooltip.classList.remove('visible'); tooltip.setAttribute('aria-hidden','true'); }, 80);
  }
  document.addEventListener('mouseover', e => { const c = (e.target as HTMLElement).closest<HTMLElement>('.chord'); if (c) { showTooltip(c); positionTooltip(e.clientX, e.clientY); } });
  document.addEventListener('mousemove', e => { if ((e.target as HTMLElement).closest('.chord')) positionTooltip(e.clientX, e.clientY); });
  document.addEventListener('mouseout', e => { const rel = e.relatedTarget as HTMLElement|null; if ((e.target as HTMLElement).closest('.chord') && (!rel || !rel.closest('.chord'))) hideTooltipSoon(); });

  // ── Acordes utilizados ────────────────────────────────────────────────────────
  function renderAcordesSection() {
    const section = document.getElementById('acordes-section')!;
    const seen = new Set<string>(); const unique: string[] = [];
    for (const sec of sections) {
      for (const line of sec.lines) {
        if ('chords' in line) for (const { c } of line.chords) {
          const name = transposeChordName(c, transposeOffset);
          if (!seen.has(name)) { seen.add(name); unique.push(name); }
        }
      }
    }
    if (!unique.length) { section.style.display = 'none'; return; }
    section.style.display = '';
    section.innerHTML = `<h2 class="acordes-titulo">Acordes utilizados</h2><div class="acordes-grid">${
      unique.map(c => {
        const svg = chordSvgs[c] || chordSvgs[transposeChordName(c, -transposeOffset)];
        return `<div class="chord-card"><div class="chord-card-name">${c}</div>${svg ? `<div class="chord-card-svg">${svg}</div>` : `<div class="chord-card-no-svg">—</div>`}</div>`;
      }).join('')
    }</div>`;
  }

  // ── Músicas parecidas ─────────────────────────────────────────────────────────
  async function loadSimilares() {
    const res = await fetch(`/api/musicas/${slug}/similares`);
    const similares: any[] = await res.json();
    if (!similares.length) return;
    const section = document.getElementById('similares-section')!;
    const grid = document.getElementById('similares-grid')!;
    grid.innerHTML = similares.map(m => `
      <a href="/musica/${m.slug}" class="recente-card">
        <span class="recente-titulo">${m.titulo}</span>
        <span class="recente-artista">${m.artista}</span>
      </a>
    `).join('');
    section.style.display = '';
  }

  // ── Favorito ──────────────────────────────────────────────────────────────────
  let isFavorito = false;
  function setFavorito(fav: boolean) {
    isFavorito = fav;
    const btn = document.getElementById('btn-favorito')!;
    btn.textContent = fav ? '❤️' : '♡';
    btn.style.opacity = fav ? '1' : '0.5';
  }
  document.getElementById('btn-favorito')?.addEventListener('click', async () => {
    const method = isFavorito ? 'DELETE' : 'POST';
    await fetch(`/api/favoritos/${slug}`, { method });
    setFavorito(!isFavorito);
  });

  function abrirModalEditar() {
    if (!currentMusica) return;
    (document.getElementById('edit-titulo') as HTMLInputElement).value = currentMusica.titulo || '';
    (document.getElementById('edit-artista') as HTMLInputElement).value = currentMusica.artista || '';
    (document.getElementById('edit-tom') as HTMLInputElement).value = currentMusica.tom || '';
    (document.getElementById('edit-tom-original') as HTMLInputElement).value = currentMusica.tom_original || '';
    (document.getElementById('edit-tags') as HTMLInputElement).value = (currentMusica.tags || []).join(', ');
    (document.getElementById('edit-link-cifraclub') as HTMLInputElement).value = currentMusica.link_cifraclub || '';
    (document.getElementById('edit-link-youtube') as HTMLInputElement).value = currentMusica.link_youtube || '';
    (document.getElementById('edit-cifra') as HTMLTextAreaElement).value = currentMusica.cifra || '';
    const errorEl = document.getElementById('edit-error') as HTMLElement;
    errorEl.textContent = '';
    errorEl.style.display = 'none';
    const btn = document.getElementById('btn-salvar-editar') as HTMLButtonElement;
    btn.disabled = false;
    btn.textContent = 'Salvar';
    document.getElementById('modal-editar-musica')!.style.display = '';
  }

  function fecharModalEditar() {
    document.getElementById('modal-editar-musica')!.style.display = 'none';
  }

  document.getElementById('btn-editar-musica')?.addEventListener('click', abrirModalEditar);
  document.getElementById('btn-fechar-editar')?.addEventListener('click', fecharModalEditar);
  document.getElementById('btn-cancelar-editar')?.addEventListener('click', fecharModalEditar);

  document.getElementById('form-editar-musica')?.addEventListener('submit', async e => {
    e.preventDefault();
    const btn = document.getElementById('btn-salvar-editar') as HTMLButtonElement;
    const errorEl = document.getElementById('edit-error') as HTMLElement;
    btn.disabled = true;
    btn.textContent = 'Salvando...';
    errorEl.style.display = 'none';

    try {
      const payload = {
        titulo: (document.getElementById('edit-titulo') as HTMLInputElement).value.trim(),
        artista: (document.getElementById('edit-artista') as HTMLInputElement).value.trim(),
        tom: (document.getElementById('edit-tom') as HTMLInputElement).value.trim(),
        tom_original: (document.getElementById('edit-tom-original') as HTMLInputElement).value.trim(),
        tags: (document.getElementById('edit-tags') as HTMLInputElement).value.split(',').map(t => t.trim()).filter(Boolean),
        cifra: (document.getElementById('edit-cifra') as HTMLTextAreaElement).value,
        link_cifraclub: (document.getElementById('edit-link-cifraclub') as HTMLInputElement).value.trim(),
        link_youtube: (document.getElementById('edit-link-youtube') as HTMLInputElement).value.trim(),
      };

      const res = await fetch(`/api/musicas/${slug}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Erro ao salvar musica');
      window.location.reload();
    } catch (err: any) {
      errorEl.textContent = err.message || 'Erro ao salvar musica';
      errorEl.style.display = '';
      btn.disabled = false;
      btn.textContent = 'Salvar';
    }
  });

  document.getElementById('btn-apagar-musica')?.addEventListener('click', async () => {
    if (!currentMusica) return;
    const ok = confirm(`Apagar "${currentMusica.titulo}"? Esta ação não pode ser desfeita.`);
    if (!ok) return;

    const btn = document.getElementById('btn-apagar-musica') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Apagando...';

    try {
      const res = await fetch(`/api/musicas/${slug}`, { method: 'DELETE' });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Erro ao apagar musica');
      window.location.href = '/';
    } catch (err: any) {
      alert(err.message || 'Erro ao apagar musica');
      btn.disabled = false;
      btn.textContent = 'Apagar';
    }
  });

  // ── Salvar meu tom ────────────────────────────────────────────────────────────
  document.getElementById('btn-salvar-tom')?.addEventListener('click', async () => {
    const key = currentKey();
    if (!key) return;
    const btn = document.getElementById('btn-salvar-tom') as HTMLButtonElement;
    btn.disabled = true;
    await Promise.all([
      fetch(`/api/user-tom/${slug}`, { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({ tom: key }) }),
      fetch(`/api/transpose/${slug}`, { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({ offset: transposeOffset }) }),
    ]).catch(() => {});
    savedUserTom = key;
    btn.style.display = 'none';
    btn.disabled = false;
    const msg = document.getElementById('tom-saved-msg')!;
    msg.style.display = '';
    setTimeout(() => { msg.style.display = 'none'; }, 2000);
  });

  // ── YouTube embed ─────────────────────────────────────────────────────────────
  function getYoutubeId(url: string): string | null {
    const m = url.match(/(?:v=|youtu\.be\/)([A-Za-z0-9_-]{11})/);
    return m ? (m[1] ?? null) : null;
  }

  // ── Init ──────────────────────────────────────────────────────────────────────
  async function init() {
    try {
      const res = await fetch(`/api/musicas/${slug}`);
      if (!res.ok) throw new Error('Música não encontrada');
      const m = await res.json();
      currentMusica = m;

      chordSvgs = m.chord_svgs || {};
      sections = parseCifra(m.cifra || '');
      const rawBaseTom = m.tom || m.tom_original || '';
      baseTom = (FLAT_TO_SHARP[rawBaseTom] ?? rawBaseTom) || '';
      savedUserTom = (FLAT_TO_SHARP[m.user_tom] ?? m.user_tom) || '';
      const normTomOriginal = (FLAT_TO_SHARP[m.tom_original] ?? m.tom_original) || baseTom;
      // Offset para o Reset: volta ao tom_original
      resetOffset = baseTom && normTomOriginal ? offsetToReachKey(baseTom, normTomOriginal) : 0;
      // Offset inicial: tom salvo pelo usuário (se houver) ou user_transpose
      if (baseTom && savedUserTom) {
        transposeOffset = offsetToReachKey(baseTom, savedUserTom);
      } else {
        transposeOffset = m.user_transpose ?? resetOffset;
      }

      // Preencher cabeçalho
      document.title = `${m.titulo} — Songbook`;
      (document.getElementById('m-titulo') as HTMLElement).textContent = m.titulo;
      const artistaEl = document.getElementById('m-artista') as HTMLAnchorElement;
      artistaEl.textContent = m.artista;
      artistaEl.href = `/?artista=${encodeURIComponent(m.artista)}`;

      if (m.tom_original) {
        const tomEl = document.getElementById('m-tom-original')!;
        tomEl.textContent = `Tom original: ${m.tom_original}`;
        tomEl.style.display = '';
      }

      // Tags
      const tagsEl = document.getElementById('m-tags')!;
      tagsEl.innerHTML = (m.tags || []).map((t: string) =>
        `<a class="tag-pill" href="/?tag=${encodeURIComponent(t)}">#${t}</a>`
      ).join('');

      // Adicionado por
      if (m.adicionado_por_username) {
        const addEl = document.getElementById('m-adicionado-por')!;
        addEl.textContent = `adicionado por ${m.adicionado_por_username}`;
        addEl.style.display = '';
      }

      // Links externos
      const linksEl = document.getElementById('m-links')!;
      if (m.link_cifraclub) {
        const a = document.getElementById('link-cifraclub') as HTMLAnchorElement;
        a.href = m.link_cifraclub; a.style.display = '';
        linksEl.style.display = '';
      }
      if (m.link_youtube) {
        const a = document.getElementById('link-youtube-btn') as HTMLAnchorElement;
        a.href = m.link_youtube; a.style.display = '';
        linksEl.style.display = '';
        // Embed
        const ytId = getYoutubeId(m.link_youtube);
        if (ytId) {
          const iframe = document.getElementById('yt-embed') as HTMLIFrameElement;
          iframe.src = `https://www.youtube-nocookie.com/embed/${ytId}`;
          document.getElementById('yt-embed-wrap')!.style.display = '';
        }
      }

      // Favorito
      setFavorito(m.favorito);

      // Render cifra
      renderCifra();

      // Show
      document.getElementById('musica-loading')!.style.display = 'none';
      document.getElementById('musica-app')!.style.display = '';

      // Parecidas
      loadSimilares();

    } catch (err: any) {
      document.getElementById('musica-loading')!.style.display = 'none';
      const errEl = document.getElementById('musica-error')!;
      errEl.textContent = err.message || 'Erro ao carregar música';
      errEl.style.display = '';
    }
  }

  init();

  // ── Event listeners ───────────────────────────────────────────────────────────
  document.querySelectorAll<HTMLElement>('.transpose-btn').forEach(btn => {
    btn.addEventListener('click', () => { applyTranspose(transposeOffset + Number(btn.dataset['dir'])); });
  });
  document.getElementById('btn-reset-transpose')?.addEventListener('click', () => applyTranspose(resetOffset));

  document.querySelectorAll<HTMLElement>('.col-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      numCols = Number(btn.dataset['cols']); localStorage.setItem('gm:colunas', String(numCols)); renderCifra();
    });
  });

  document.getElementById('btn-pratica')?.addEventListener('click', () => {
    praticaMode = !praticaMode;
    (document.getElementById('btn-pratica') as HTMLButtonElement).textContent = praticaMode ? '📄 Ver cifra' : '🎯 Modo Prática';
    renderCifra();
  });
</script>


---
import { getCollection, render } from 'astro:content';
import Base from '../layouts/Base.astro';

const fases = await getCollection('plano');
fases.sort((a, b) => a.data.fase - b.data.fase);

const rendered = await Promise.all(
  fases.map(async f => ({ data: f.data, id: f.id, html: await render(f) }))
);
---

<Base title="Study Plan">
  <div class="page-head">
    <h1 class="page-title" data-i18n="plan_title">Study Plan</h1>
    <p class="page-sub" data-i18n="plan_subtitle">Track your progress — saved automatically</p>
  </div>

  <div class="fases">
    {rendered.map(({ data, id, html }) => {
      const { Content } = html;
      return (
        <article class="paper-card fase prose-cifra" data-fase-id={id}>
          <header class="fase-head">
            <span class="meta-badge phase-label" data-fase={data.fase}>Phase {data.fase}</span>
            {data.duracao && <span class="fase-dur">{data.duracao}</span>}
          </header>
          <div class="fase-body">
            <Content />
          </div>
        </article>
      );
    })}
  </div>
</Base>

<style>
  .page-head { margin-bottom: 2rem; }
  .page-title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    color: var(--ink);
    letter-spacing: -0.01em;
  }
  .page-sub { font-style: italic; color: var(--ink-soft); font-size: 0.95rem; }

  .fases {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }
  .fase {
    padding: 1.4rem 1.6rem 1.6rem;
  }
  .fase-head {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    margin-bottom: 0.8rem;
  }
  .fase-dur {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.85rem;
    color: var(--ink-soft);
  }

  .fase-body :global(h2),
  .fase-body :global(h3) {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    color: var(--ink);
    margin-top: 1rem;
    margin-bottom: 0.5rem;
  }
  .fase-body :global(h2) { font-size: 1.4rem; }
  .fase-body :global(h3) { font-size: 1.15rem; }
  .fase-body :global(p) {
    font-family: var(--font-serif);
    color: var(--ink);
    line-height: 1.55;
    margin-bottom: 0.6rem;
  }
  .fase-body :global(strong) { color: var(--accent); font-weight: 700; }
  .fase-body :global(ul) {
    list-style: none;
    padding-left: 0;
    margin: 0.4rem 0 0.8rem;
  }
  .fase-body :global(li) {
    font-family: var(--font-serif);
    line-height: 1.5;
    margin-bottom: 0.25rem;
    color: var(--ink);
  }
  .fase-body :global(li:has(input[type="checkbox"])) {
    padding-left: 0;
  }
  .fase-body :global(input[type="checkbox"]) {
    accent-color: var(--accent);
    margin-right: 0.5rem;
    cursor: pointer;
    transform: translateY(1px);
  }
</style>

<script>
  import { t, getLang } from '../lib/i18n.js';

  const PREFIX = 'gm:plano:';

  document.querySelectorAll<HTMLInputElement>('input[type="checkbox"]').forEach((cb, i) => {
    const key = `${PREFIX}${i}`;
    cb.disabled = false;
    cb.checked = localStorage.getItem(key) === '1';
    cb.addEventListener('change', () => {
      localStorage.setItem(key, cb.checked ? '1' : '0');
    });
  });

  function updatePhaseLabels() {
    document.querySelectorAll<HTMLElement>('.phase-label').forEach(el => {
      const n = el.dataset['fase'];
      el.textContent = `${t('phase')} ${n}`;
    });
  }

  updatePhaseLabels();
  document.addEventListener('gm:lang-change', updatePhaseLabels);
</script>

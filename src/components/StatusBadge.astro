---
interface Props {
  status: 'toca_bem' | 'toca_parcial' | 'wishlist' | 'nao_classificado';
  class?: string;
}

const { status, class: cls } = Astro.props;

const config = {
  toca_bem:         { emoji: '🟢', label: 'Plays well',  key: 'status_toca_bem' },
  toca_parcial:     { emoji: '🟡', label: 'Partial',     key: 'status_parcial' },
  wishlist:         { emoji: '🔴', label: 'Wishlist',    key: 'status_wishlist' },
  nao_classificado: { emoji: '⚪', label: 'No status',   key: 'status_sem_status' },
} as const;

const { emoji, label, key } = config[status];
---

<span
  class:list={['status-badge', `status-${status}`, cls]}
  aria-label={label}
  title={label}
>
  <span aria-hidden="true">{emoji}</span>
  <span data-i18n={key}>{label}</span>
</span>

<style>
  .status-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-family: var(--font-serif);
    font-size: 0.78rem;
    font-style: italic;
    color: var(--ink-soft);
    padding: 0.1rem 0.5rem;
    border-radius: 3px;
    border: 1px solid var(--paper-line);
    background: color-mix(in srgb, var(--bg) 50%, transparent);
  }
</style>

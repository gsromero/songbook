---
interface Props {
  artistas: string[];
  tags: string[];
}
const { artistas } = Astro.props;

const niveis = ['N1', 'N2', 'N3', 'N4', 'N5'];
const statuses = [
  { value: 'toca_bem',         i18nKey: 'status_filter_plays_well', label: '🟢 Plays well' },
  { value: 'toca_parcial',     i18nKey: 'status_filter_partial',    label: '🟡 Partial' },
  { value: 'wishlist',         i18nKey: 'status_filter_wishlist',   label: '🔴 Wishlist' },
  { value: 'nao_classificado', i18nKey: 'status_filter_no_status',  label: '⚪ No status' },
];
---

<div class="controls filtros">
  <div class="ctrl-group">
    <span class="ctrl-label" data-i18n="filter_search">Search</span>
    <input
      id="filtro-busca"
      type="search"
      placeholder="Title or artist…"
      data-i18n-placeholder="filter_search_placeholder"
      class="input filtro-busca-input"
    />
  </div>

  <div class="ctrl-group">
    <span class="ctrl-label" data-i18n="filter_level">Level</span>
    <div class="btn-row">
      {niveis.map(n => (
        <button class="btn filtro-nivel" data-nivel={n} aria-pressed="false" type="button">{n}</button>
      ))}
    </div>
  </div>

  <div class="ctrl-group">
    <span class="ctrl-label" data-i18n="filter_status">Status</span>
    <div class="btn-row">
      {statuses.map(s => (
        <button class="btn filtro-status" data-status={s.value} aria-pressed="false" type="button" data-i18n={s.i18nKey}>{s.label}</button>
      ))}
    </div>
  </div>

  <div class="ctrl-group">
    <span class="ctrl-label" data-i18n="filter_artist">Artist</span>
    <select id="filtro-artista" class="input">
      <option value="" data-i18n="filter_all">All</option>
      {artistas.sort((a, b) => a.localeCompare(b, 'pt')).map(a => <option value={a}>{a}</option>)}
    </select>
  </div>

  <button id="filtro-limpar" class="btn btn-ghost" type="button" data-i18n="filter_clear">Clear</button>

  <span id="filtro-count" class="ctrl-label filtro-count"></span>
</div>

<style>
  .filtros { margin-bottom: 1.5rem; }
  .btn-row { display: flex; gap: 2px; flex-wrap: wrap; }
  .filtro-busca-input { width: 14rem; }
  .btn-ghost { border-color: transparent; background: transparent; color: var(--ink-soft); }
  .btn-ghost:hover { color: var(--accent); background: transparent; border-color: var(--paper-line); }
  .filtro-count { margin-left: auto; text-transform: none; letter-spacing: 0; font-style: italic; }
  @media (max-width: 700px) { .filtro-busca-input { width: 100%; } }
</style>

<script>
  import { t, getLang } from '../lib/i18n.js';

  type FilterState = {
    busca: string;
    niveis: Set<string>;
    statuses: Set<string>;
    artista: string;
  };

  const state: FilterState = { busca: '', niveis: new Set(), statuses: new Set(), artista: '' };

  function readUrl() {
    const params = new URLSearchParams(location.search);
    state.busca = params.get('q') ?? '';
    state.niveis = new Set(params.getAll('nivel'));
    state.statuses = new Set(params.getAll('status'));
    state.artista = params.get('artista') ?? '';
  }

  function pushUrl() {
    const params = new URLSearchParams();
    if (state.busca) params.set('q', state.busca);
    state.niveis.forEach(n => params.append('nivel', n));
    state.statuses.forEach(s => params.append('status', s));
    if (state.artista) params.set('artista', state.artista);
    const qs = params.toString();
    history.replaceState(null, '', qs ? `?${qs}` : location.pathname);
  }

  function updateCount(visible: number) {
    const countEl = document.getElementById('filtro-count');
    if (!countEl) return;
    const lang = getLang();
    const word = lang === 'pt' ? (visible !== 1 ? 'músicas' : 'música') : (visible !== 1 ? 'songs' : 'song');
    countEl.textContent = `${visible} ${word}`;
  }

  function applyFilters() {
    const cards = document.querySelectorAll<HTMLElement>('[data-musica-card]');
    let visible = 0;
    cards.forEach(card => {
      const titulo = (card.dataset['titulo'] ?? '').toLowerCase();
      const artista = (card.dataset['artista'] ?? '').toLowerCase();
      const nivel = card.dataset['nivel'] ?? '';
      const status = card.dataset['status'] ?? '';
      const matchBusca = !state.busca || titulo.includes(state.busca.toLowerCase()) || artista.includes(state.busca.toLowerCase());
      const matchNivel = state.niveis.size === 0 || state.niveis.has(nivel);
      const matchStatus = state.statuses.size === 0 || state.statuses.has(status);
      const matchArtista = !state.artista || artista === state.artista.toLowerCase();
      const show = matchBusca && matchNivel && matchStatus && matchArtista;
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    updateCount(visible);
    pushUrl();
    syncUi();
  }

  function syncUi() {
    const busca = document.getElementById('filtro-busca') as HTMLInputElement | null;
    if (busca) busca.value = state.busca;
    document.querySelectorAll<HTMLElement>('.filtro-nivel').forEach(btn => {
      btn.setAttribute('aria-pressed', String(state.niveis.has(btn.dataset['nivel'] ?? '')));
    });
    document.querySelectorAll<HTMLElement>('.filtro-status').forEach(btn => {
      btn.setAttribute('aria-pressed', String(state.statuses.has(btn.dataset['status'] ?? '')));
    });
    const artista = document.getElementById('filtro-artista') as HTMLSelectElement | null;
    if (artista) artista.value = state.artista;
  }

  document.getElementById('filtro-busca')?.addEventListener('input', e => {
    state.busca = (e.target as HTMLInputElement).value;
    applyFilters();
  });
  document.querySelectorAll<HTMLElement>('.filtro-nivel').forEach(btn => {
    btn.addEventListener('click', () => {
      const n = btn.dataset['nivel'] ?? '';
      if (state.niveis.has(n)) state.niveis.delete(n); else state.niveis.add(n);
      applyFilters();
    });
  });
  document.querySelectorAll<HTMLElement>('.filtro-status').forEach(btn => {
    btn.addEventListener('click', () => {
      const s = btn.dataset['status'] ?? '';
      if (state.statuses.has(s)) state.statuses.delete(s); else state.statuses.add(s);
      applyFilters();
    });
  });
  document.getElementById('filtro-artista')?.addEventListener('change', e => {
    state.artista = (e.target as HTMLSelectElement).value;
    applyFilters();
  });
  document.getElementById('filtro-limpar')?.addEventListener('click', () => {
    state.busca = ''; state.niveis.clear(); state.statuses.clear(); state.artista = '';
    applyFilters();
  });
  document.addEventListener('gm:lang-change', () => applyFilters());

  readUrl();
  applyFilters();
</script>

---
interface Props {
  targetId?: string;
}
const { targetId } = Astro.props;
---

<div class="ctrl-group" role="group" data-i18n-aria="column_aria" aria-label="Number of columns">
  <span class="ctrl-label" data-i18n="columns">Columns</span>
  <div class="col-btns">
    {[1, 2, 3, 4].map(n => (
      <button
        class="btn col-btn"
        data-cols={n}
        data-target={targetId}
        aria-pressed="false"
        type="button"
        title={`${n} column${n > 1 ? 's' : ''}`}
      >
        {n}
      </button>
    ))}
  </div>
</div>

<style>
  .col-btns {
    display: flex;
    gap: 2px;
  }
  .col-btn {
    min-width: 2rem;
    padding: 0.35rem 0.55rem;
  }
</style>

<script>
  import { t } from '../lib/i18n.js';

  const STORAGE_KEY = 'gm:colunas';

  function updateTitles() {
    document.querySelectorAll<HTMLElement>('.col-btn').forEach(btn => {
      const n = Number(btn.dataset['cols']);
      const word = t('columns').toLowerCase();
      btn.title = `${n} ${n > 1 ? word : word.replace(/s$/, '')}`;
    });
  }

  function apply(n: number) {
    document.querySelectorAll<HTMLElement>('.col-btn').forEach(btn => {
      btn.setAttribute('aria-pressed', String(Number(btn.dataset['cols']) === n));
    });
    localStorage.setItem(STORAGE_KEY, String(n));
    document.dispatchEvent(new CustomEvent('gm:cols-change', { detail: n }));
  }

  const stored = Number(localStorage.getItem(STORAGE_KEY) ?? '1');
  apply(stored);
  updateTitles();

  document.querySelectorAll<HTMLElement>('.col-btn').forEach(btn => {
    btn.addEventListener('click', () => apply(Number(btn.dataset['cols'])));
  });

  document.addEventListener('gm:lang-change', () => updateTitles());
</script>

---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  wide?: boolean;
  full?: boolean;
}

const { title, description = 'Guitar chord sheet catalogue', wide = false, full = false } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <title>{title} — Guitar Master</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Crimson+Pro:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Cormorant+Garamond:ital,wght@0,500;0,600;1,500&family=JetBrains+Mono:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <script is:inline>
      // Apply theme and language before first paint to prevent flash
      (function () {
        try {
          var theme = localStorage.getItem('gm:theme');
          if (theme === 'dark') document.documentElement.setAttribute('data-theme', 'dark');
          var lang = localStorage.getItem('gm:lang') || 'en';
          document.documentElement.setAttribute('data-lang', lang);
        } catch (e) {}
      })();
    </script>
  </head>
  <body class="min-h-screen">
    <header class="site-header">
      <nav class:list={['site-nav px-6', full ? '' : wide ? 'mx-auto max-w-screen-2xl' : 'mx-auto max-w-6xl']}>
        <a href={base} class="brand">🎸 Guitar Master</a>
        <a href={`${base}progresso`} class="navlink" data-i18n="nav_progress">Progress</a>
        <a href={`${base}plano`} class="navlink" data-i18n="nav_plan">Plan</a>
        <div class="nav-actions">
          <button id="lang-toggle" class="btn btn-icon" type="button" title="Switch language" aria-label="Switch language">
            <span id="lang-icon">PT</span>
          </button>
          <button id="theme-toggle" class="btn btn-icon" type="button" data-i18n-aria="toggle_theme" aria-label="Toggle theme" title="Toggle theme">
            <span id="theme-icon">☾</span>
          </button>
        </div>
      </nav>
    </header>

    <main class:list={['py-6', full ? 'px-6' : wide ? 'mx-auto px-4 max-w-screen-2xl' : 'mx-auto px-4 max-w-6xl']}>
      <slot />
    </main>

    <footer class="site-footer">
      Guitar Master · {new Date().getFullYear()}
    </footer>

    <script>
      import { TRANSLATIONS, LANG_KEY, getLang, type Lang, type TranslationKey } from '../lib/i18n.js';

      // ── Theme ────────────────────────────────────────────────────────────────
      const root = document.documentElement;
      const themeBtn = document.getElementById('theme-toggle');
      const themeIcon = document.getElementById('theme-icon');

      function syncThemeIcon() {
        if (themeIcon) themeIcon.textContent = root.getAttribute('data-theme') === 'dark' ? '☀' : '☾';
      }
      syncThemeIcon();

      themeBtn?.addEventListener('click', () => {
        const isDark = root.getAttribute('data-theme') === 'dark';
        if (isDark) {
          root.removeAttribute('data-theme');
          localStorage.setItem('gm:theme', 'light');
        } else {
          root.setAttribute('data-theme', 'dark');
          localStorage.setItem('gm:theme', 'dark');
        }
        syncThemeIcon();
      });

      // ── i18n ─────────────────────────────────────────────────────────────────
      const langBtn = document.getElementById('lang-toggle');
      const langIcon = document.getElementById('lang-icon');

      function t(key: TranslationKey, lang?: Lang): string {
        const l = lang ?? getLang();
        return (TRANSLATIONS[l] as Record<string, string>)[key] ?? key;
      }

      function applyTranslations(lang?: Lang) {
        const l = lang ?? getLang();
        document.querySelectorAll<HTMLElement>('[data-i18n]').forEach(el => {
          const key = el.dataset['i18n'] as TranslationKey;
          el.textContent = t(key, l);
        });
        document.querySelectorAll<HTMLElement>('[data-i18n-placeholder]').forEach(el => {
          const key = el.dataset['i18nPlaceholder'] as TranslationKey;
          (el as HTMLInputElement).placeholder = t(key, l);
        });
        document.querySelectorAll<HTMLElement>('[data-i18n-aria]').forEach(el => {
          const key = el.dataset['i18nAria'] as TranslationKey;
          el.setAttribute('aria-label', t(key, l));
          el.setAttribute('title', t(key, l));
        });
        if (langIcon) langIcon.textContent = l === 'en' ? 'PT' : 'EN';
      }

      // Apply on load (if lang is pt, updates from server-rendered EN)
      applyTranslations();

      langBtn?.addEventListener('click', () => {
        const current = getLang();
        const next: Lang = current === 'en' ? 'pt' : 'en';
        localStorage.setItem(LANG_KEY, next);
        root.setAttribute('data-lang', next);
        applyTranslations(next);
        document.dispatchEvent(new CustomEvent('gm:lang-change', { detail: next }));
      });
    </script>

    <style>
      .site-header {
        background: color-mix(in srgb, var(--bg-tint) 90%, transparent);
        border-bottom: 1px solid var(--paper-line);
        position: sticky;
        top: 0;
        z-index: 40;
        backdrop-filter: blur(8px);
      }
      .site-nav {
        height: 3rem;
        display: flex;
        align-items: center;
        gap: 1.5rem;
      }
      .nav-actions {
        margin-left: auto;
        display: flex;
        align-items: center;
        gap: 0.4rem;
      }
      .brand {
        font-family: var(--font-display);
        font-weight: 600;
        font-size: 1.15rem;
        color: var(--ink);
        text-decoration: none;
      }
      .brand:hover { color: var(--accent); }
      .navlink {
        font-family: var(--font-serif);
        font-size: 0.95rem;
        color: var(--ink-soft);
        text-decoration: none;
        transition: color 0.15s;
      }
      .navlink:hover { color: var(--accent); }
      .btn-icon {
        min-width: 2.2rem;
        font-size: 0.85rem;
        font-family: var(--font-mono);
        font-weight: 700;
      }
      .site-footer {
        text-align: center;
        font-style: italic;
        font-size: 0.85rem;
        color: var(--ink-soft);
        opacity: 0.7;
        padding: 1.5rem 1rem 2.5rem;
        margin-top: 3rem;
        border-top: 1px solid var(--paper-line);
      }
    </style>
  </body>
</html>
